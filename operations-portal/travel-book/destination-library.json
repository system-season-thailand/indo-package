  "country": {
    "Indonesia": {
      "country_en": "Indonesia",
      "country_ar": "إندونيسيا",
      "hotels_note": [
        "الدخول للفنادق يبدأ عادة من ٢ او ٣ عصراً وتسجيل الخروج حتى ١٢ ظهراً.",
        "اذا حابب غرف متصلة، بعض الفنادق توفرها لكن حسب التوافر عند الحجز او الوصول.",
        "بعض الفنادق والفلل يطلبون تأمين عند تسجيل الدخول، والمبلغ يسترجع عند الخروج (يختلف حسب سياسة كل فندق)."
      ],
      "flights_note": [
        "الوزن المسموح 20 كيلو لكل راكب فوق عمر سنتين.",
        "لإضافة وزن إضافي يرجى إبلاغنا قبل موعد الرحلة بيومين وسيتم ترتيبه لكم بكل سهولة، تطبق رسوم إضافية على الوزن الزائد من قبل شركة الطيران."
      ],
      "itinerary_note": [
        "جولتك الخاصة لمدة ٨ ساعات تبدأ من لحظة وصول السائق إلى فندقك، حسب الموعد المتفق عليه مسبقاً (يُحدد قبلها بيوم) مع إمكانية الانطلاق في أي وقت يناسبك بين ٨ صباحاً و ١١ مساءً.",
        "استمتع بزيارة أبرز المعالم والمناطق السياحية (ضمن حدود إقامتك) لتعيش تجربة على ذوقك وبأسلوبك."
      ],
      "delivery_title": "تطبيقات التوصيل في إندونيسيا",
      "delivery_apps": [
        "Gojek",
